{
    "name": "linxio-js",
    "version": "2.22.4",
    "packageManager": "pnpm@11.5.2",
    "description": "linxio-js is a secure, lightweight, high-performance Node.js SDK for interacting with the Linxio Fleet Management API. Query vehicles, drivers, and devices, stream live GPS positions, subscribe to real-time notifications, auto-paginate large fleets, export reports, manage geofences and routes, and more!",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "docs:build": "pnpm --dir docs build",
        "docs:check": "pnpm --dir docs types:check",
        "docs:dev": "pnpm --dir docs dev",
        "analyze:sources": "pnpm build && node scripts/analyze-dashboard-sources.mjs",
        "format": "pnpm format:sdk && pnpm --dir docs format",
        "format:biome": "pnpm format:sdk",
        "format:sdk": "biome check src scripts package.json tsconfig.json tsup.config.ts pnpm-workspace.yaml --write --config-path ./biome.json",
        "lint": "pnpm lint:sdk && pnpm --dir docs lint",
        "lint:sdk": "biome check src scripts package.json tsconfig.json tsup.config.ts pnpm-workspace.yaml --config-path ./biome.json",
        "live:contract": "pnpm build && node scripts/live-contract.mjs",
        "live:contract:mutations": "pnpm build && node scripts/live-contract.mjs --mutations",
        "live:smoke": "node scripts/live-smoke.mjs",
        "prepack": "pnpm build",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm docs:check",
        "bump-deps": "npx npm-check-updates --deep -u -x @biomejs/biome"
    },
    "keywords": [
        "linxio",
        "fleet",
        "gps",
        "sdk",
        "typescript"
    ],
    "author": "Ambulance WA",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ambulancewa/linxio-js.git"
    },
    "bugs": {
        "url": "https://github.com/ambulancewa/linxio-js/issues"
    },
    "homepage": "https://github.com/ambulancewa/linxio-js#readme",
    "engines": {
        "node": ">=20.11"
    },
    "dependencies": {
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@auto-it/first-time-contributor": "^11.3.6",
        "@biomejs/biome": "2.4.15",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.8",
        "@semantic-release/npm": "^13.1.5",
        "@semantic-release/release-notes-generator": "^14.1.1",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "^25.9.2",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "prettier-plugin-tailwindcss-canonical-classes": "^0.1.5",
        "semantic-release": "^25.0.3",
        "sharp": "^0.34.5",
        "tsup": "^8.5.1",
        "turbo": "^2.9.16",
        "typed-query-selector": "^2.12.2",
        "typescript": "^6.0.3",
        "ultracite": "^7.8.1",
        "vitest": "^4.1.8"
    },
    "sideEffects": false
}
